# Quetzal settings
APP_DEBUG=true                         # Para mostrar alertar de errores o debug
DEFAULT_CONTROLLER='admin'             # Controlador por defecto a cargar si no se específica alguno
DEFAULT_ERROR_CONTROLLER='error'       # Controlador de errores por defecto
DEFAULT_METHOD='index'                 # Método por defecto a cargar
APP_DEV_PATH='/quetzal/'               # Path base para aplicación en desarrollo
APP_LIVE_PATH='/'                      # Path base para aplicación en producción
IS_SANDBOX=false                       # true o false para ambientes live/producción o sandbox/pruebas
IS_DEMO=false                          # Para funcionalidad DEMO en tu sistema, opcional

# Salts
# Recomendado generar una nueva por cada nuevo proyecto
AUTH_SALT='$2y$10$WNRjHI4M7E/rMJlKYj2Im.0Pv5qlhoRTeT6jCoFzDAAHx69gyAMS.'
NONCE_SALT=''

# API Access
# Recomendado generar una nueva por cada nuevo proyecto
API_PROTECTED=true                     # Define si se usará un token de acceso para consumir la API de Quetzal
API_PUBLIC_KEY='03d427-c4034c-d2dc71-373b10-36da67'
API_PRIVATE_KEY='51362e-0cb1b9-f9c183-17b0a3-1a002e'

# Configuraciones generales
APP_TIMEZONE='America/Mexico_City'     # Zona horaria principal de la aplicación
APP_LANG='es_MX'                       # Lenguaje principal de la aplicación
APP_CHARSET='UTF-8'                    # Charset de tu aplicación
APP_NAME='Quetzal'                     # Nombre de tu aplicación
APP_VERSION='1.0.0'                    # Versión de tu aplicación
APP_LOGO='logo.png'                    # Nombre de tu logotipo principal, deberá estar en assets/images/
APP_FAVICON='favicon.ico'              # Nombre de tu favicon del sitio, deberá estar en assets/favicon/
APP_DESC='Quetzal — un framework PHP ligero, flexible y fácil de implementar.'

# Sesiones de usuario
QUETZAL_USERS_TABLE='quetzal_users'    # Nombre de la tabla para autenticación de usuarios
COOKIE_ID_NAME='q__cookie_id'          # Nombre del cookie que guarda el ID del usuario
COOKIE_TOKEN_NAME='q__cookie_tkn'      # Nombre del cookie que guarda el token
COOKIE_LIFETIME='month'                # Valores disponibles: day, week, month, year
COOKIE_PATH='/'                        # Path de cookies
COOKIE_DOMAIN=''                       # Dominio de cookies
COOKIE_HTTPS=false                     # Serán válidos solo en HTTPS

# Envío de correos y servidor SMTP
PHPMAILER_EXCEPTIONS=true              # Mantener activo para recibir excepciones en errores de Phpmailer
PHPMAILER_SMTP=false                   # Activar uso de cuenta SMTP para envío de correos true o false
PHPMAILER_DEBUG=false                  # Solo activar si es necesario el log verboso para debug
PHPMAILER_HOST='smtp.example.com'      # Dominio o servidor SMTP
PHPMAILER_AUTH=true                    # Autenticar con SMTP true o false
PHPMAILER_USERNAME='user@example.com'  # Usuario de la cuenta tucorreo@algo.com
PHPMAILER_PASSWORD='123secret'         # Password de la cuenta
PHPMAILER_SECURITY='tls'               # Tipo de seguridad, opciones tls o ssl
PHPMAILER_PORT='465'                   # Puerto de conexión SMTP -- 587 hotmail -- 465 gmail
PHPMAILER_TEMPLATE='emailTemplate'     # Plantilla por defecto de correo electrónico dentro de tu proyecto

# Plugins básicos incorporados
CSS_FRAMEWORK='bs_flatly'              # Opciones disponibles: bs o bs5 = Bootstrap 5 | bl = Bulma | fn = Foundation
USE_JQUERY=true
USE_VUEJS=true
USE_AXIOS=false
USE_SWEETALERT2=true
USE_TOASTR=true
USE_WAITME=true
USE_LIGHTBOX=true
USE_BLADE=true

# Credenciales de desarrollo
LDB_ENGINE='mysql'
LDB_HOST='localhost'
LDB_NAME='db_quetzal'
LDB_USER='root'
LDB_PASS=''
LDB_CHARSET='utf8'

# Credenciales de producción
DB_ENGINE='mysql'
DB_HOST='localhost'
DB_NAME=''
DB_USER=''
DB_PASS=''
DB_CHARSET='utf8'

# Configuraciones adicionales
CUSTOM_SETTING='Hola soy un custom setting'