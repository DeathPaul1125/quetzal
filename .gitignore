composer.phar
/vendor/
vendor
.composer/

# Configuración local de Claude Code (no se versiona)
.claude/*
.claude/settings.json

# Nota: composer.lock SÍ se versiona — garantiza que todos instalen las
# mismas versiones exactas de dependencias (`composer install` reproducible).
# Sin lock file, composer hace `update` en cada clone y puede traer versiones
# nuevas con bugs o cambios que rompan el sistema.

app/config/config.php
app/controllers/pruebasController.php
templates/views/pruebas/
.env

# Nota: install.php SÍ se versiona.
# El wizard lo auto-elimina localmente tras instalar, pero debe estar en git
# para que clones frescos puedan correrlo.

# Plugins de desarrollo (no se versionan con el framework core).
# Cada plugin se versiona en su propio repo / paquete.
/plugins/*/
!/plugins/.gitkeep